generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys      ApiKey[]
  requests     Request[]
  billing      Billing?
  transactions CreditTransaction[]
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    @unique
  name      String
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Request {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  query   String
  sources String
  limit   Int    @default(20)
  status  String @default("pending")
  cost    Float  @default(0)

  result Result?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Result {
  id        String  @id @default(cuid())
  requestId String  @unique
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  rawData  String
  problems String
  summary  String
  trends   String

  createdAt DateTime @default(now())
}

model Billing {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeId        String?   // Stripe customer ID
  stripeSubId     String?   // Active subscription ID (null if PAYG-only)

  // Plan: "free" | "payg" | "growth" | "pro" | "enterprise"
  plan            String @default("free")

  // Credits pool — shared between PAYG top-ups and subscription allowance
  credits         Int    @default(0)
  totalSpent      Float  @default(0)

  // Subscription tracking (for sub plans only)
  subCreditsPerCycle  Int?      // credits granted per billing cycle
  subResetAt          DateTime? // when the next cycle resets credits

  // Counters
  totalSearches   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "purchase" | "subscription_grant" | "spend" | "refund" | "subscription_reset"
  type        String
  credits     Int     // positive = added, negative = deducted
  amountCents Int     @default(0)
  description String
  stripeId    String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
