# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./uncover.db"
# Production: DATABASE_URL="postgresql://user:pass@host:5432/uncover"

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000

# ── AI Analysis ───────────────────────────────────────────────────────────────
AI_PROVIDER=groq
AI_API_KEY=your_key_here
AI_MODEL=llama-3.1-8b-instant

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PAYG Credit Packs (one-time payments)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PACK_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# Subscription Plans (recurring monthly)
STRIPE_BUILDER_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Web ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
