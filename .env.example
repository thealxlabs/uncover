# ── Database ────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL="file:./uncover.db"
# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL="postgresql://user:password@host:5432/uncover"

# ── API Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000

# ── AI Analysis ─────────────────────────────────────────────────
AI_PROVIDER=groq           # groq | openrouter | ollama
AI_API_KEY=your_key_here
AI_MODEL=llama-3.1-8b-instant

# ── Stripe ──────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products in Stripe dashboard, then paste the price IDs:
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Web App ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
