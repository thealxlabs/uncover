# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./uncover.db"
# Production: DATABASE_URL="postgresql://user:pass@host:5432/uncover"

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000

# ── AI Analysis ───────────────────────────────────────────────────────────────
AI_PROVIDER=groq
AI_API_KEY=your_key_here
AI_MODEL=llama-3.1-8b-instant

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PAYG Credit Packs (one-time payments) ───────────────────────────────────────
# Create each as a ONE-TIME product in Stripe dashboard
# Starter Pack  — 50 searches  — $5.00
STRIPE_STARTER_PRICE_ID=price_...
# Growth Pack   — 200 searches — $15.00
STRIPE_GROWTH_PRICE_ID=price_...
# Pro Pack      — 500 searches — $29.00
STRIPE_PRO_PACK_PRICE_ID=price_...
# Scale Pack    — 2000 searches — $79.00
STRIPE_SCALE_PRICE_ID=price_...

# Subscription Plans (recurring monthly) ──────────────────────────────────────
# Create each as a RECURRING product in Stripe dashboard
# Builder    — 300 searches/mo  — $19/mo
STRIPE_BUILDER_PRICE_ID=price_...
# Team       — 1000 searches/mo — $49/mo
STRIPE_TEAM_PRICE_ID=price_...
# Enterprise — 5000 searches/mo — $149/mo
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Web ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
