# Database
DATABASE_URL="file:./uncover.db"

# API
PORT=3001
NODE_ENV=development

# ─── AI Provider ────────────────────────────────────────────────────────────
# Choose: "groq" | "openrouter" | "ollama"
AI_PROVIDER=groq

# Groq (free tier) → https://console.groq.com
# Good free models: llama-3.1-8b-instant, llama-3.3-70b-versatile, gemma2-9b-it
AI_API_KEY=gsk_...
AI_MODEL=llama-3.1-8b-instant

# OpenRouter (free tier) → https://openrouter.ai
# Good free models: meta-llama/llama-3.1-8b-instruct:free, qwen/qwen-2.5-7b-instruct:free
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-...
# AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Ollama (local, free) → https://ollama.com
# AI_PROVIDER=ollama
# AI_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama  # can be anything for local

# ─── Next.js Web ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Stripe (Phase 2) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Redis (Phase 2) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
